<Window x:Class="Restoran.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restoran"
        mc:Ignorable="d"
            Title="Сервис для ресторана" Height="700" Width="1100" MinHeight="500" MinWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        <Frame Grid.Row="1" x:Name="MaineFrame" NavigationUIVisibility="Hidden" ContentRendered="MainFrame_ContentRendered" Background="White"/>
        <Grid>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0,0" StartPoint="1,1">
                    <GradientStop Color="#FFFF7F" Offset="0"/>
                    <GradientStop  Color="GreenYellow" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>
        <TextBlock
        Text="{Binding ElementName=MaineFrame, Path=Content.Title}"
        FontSize="35" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
        <Button HorizontalAlignment="Right" Grid.Row="2" Click="BtnBack_Back" Content="Назад" x:Name="BtnBack" FontSize="20" Width="200" Height="50"/>
    </Grid>
</Window>
