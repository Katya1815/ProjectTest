<Page x:Class="Restoran.Pages.ClientOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мои заказы"
      Background="#FFF5F0">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="МОИ ЗАКАЗЫ"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#FF9721"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Кнопка "Сделать заказ" -->
        <Button Grid.Row="1"
                Content="➕ СДЕЛАТЬ НОВЫЙ ЗАКАЗ"
                Height="50"
                Width="300"
                HorizontalAlignment="Center"
                Click="BtnMakeOrder_Click"
                Background="#FF9721"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="Bold"
                Cursor="Hand"
                Margin="0,0,0,20">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>

        <!-- Список заказов -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="OrdersItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#FF9721"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,0,0,10"
                                Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Номер заказа и статус -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Заказ №" Foreground="#FF9721" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding IdЗаказа}" FontWeight="Bold" FontSize="14" Margin="0,0,15,0"/>
                                    <TextBlock Text="Статус:" Foreground="#FF9721" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Статус}" FontWeight="Bold" FontSize="14" Margin="5,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Gray"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Статус}" Value="Новый">
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Статус}" Value="В обработке">
                                                        <Setter Property="Foreground" Value="Blue"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Статус}" Value="Готовится">
                                                        <Setter Property="Foreground" Value="Orange"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Статус}" Value="Готов">
                                                        <Setter Property="Foreground" Value="Purple"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Статус}" Value="Доставлен">
                                                        <Setter Property="Foreground" Value="Teal"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Статус}" Value="Отменен">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Дата, время, сумма -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Дата:" Foreground="#FF9721" FontSize="13"/>
                                    <TextBlock Text="{Binding ДатаПринятияЗаказа, StringFormat={}{0:dd.MM.yyyy}}" Margin="5,0,15,0" FontSize="13"/>
                                    <TextBlock Text="Время:" Foreground="#FF9721" FontSize="13"/>
                                    <TextBlock Text="{Binding ВремяПринятияЗаказа}" Margin="5,0,15,0" FontSize="13"/>
                                    <TextBlock Text="Сумма:" Foreground="#FF9721" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Сумма, StringFormat={}{0:N2} ₽}" FontWeight="Bold" FontSize="14" Foreground="#FF9721" Margin="5,0,0,0"/>
                                </StackPanel>

                                <!-- Кнопки действий -->
                                <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="🔄 Повторить" Width="100" Height="35" Margin="5" Click="BtnRepeatOrder_Click" Tag="{Binding IdЗаказа}"
                                            Background="Transparent" BorderBrush="#FF9721" BorderThickness="2" Foreground="#FF9721" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <Button Content="❌ Отменить" Width="90" Height="35" Margin="5" Click="BtnCancelOrder_Click" Tag="{Binding IdЗаказа}"
                                            Background="Transparent" BorderBrush="Red" BorderThickness="2" Foreground="Red" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="5"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>