<Page x:Class="Restoran.Pages.ClientAuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация клиента"
      Height="500" 
      Width="300"
      Background="#FFF5F0">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="1" 
                   Text="АВТОРИЗАЦИЯ КЛИЕНТА" 
                   FontSize="18" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"
                   Foreground="#FF9721"/>

        <TextBlock Grid.Row="2" 
                   Text="Фамилия:" 
                   FontSize="14"
                   Margin="0,0,0,5"
                   Foreground="#FF9721"/>

        <TextBox Grid.Row="3" 
                 x:Name="TBoxLastName"
                 Height="30"
                 FontSize="14"
                 Margin="0,0,0,15"
                 BorderBrush="#FF9721"
                 BorderThickness="1">
            <TextBox.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </TextBox.Resources>
        </TextBox>

        <TextBlock Grid.Row="4" 
                   Text="Имя:" 
                   FontSize="14"
                   Margin="0,0,0,5"
                   Foreground="#FF9721"/>

        <TextBox Grid.Row="5" 
                 x:Name="TBoxFirstName"
                 Height="30"
                 FontSize="14"
                 Margin="0,0,0,15"
                 BorderBrush="#FF9721"
                 BorderThickness="1">
            <TextBox.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </TextBox.Resources>
        </TextBox>

        <Button Grid.Row="6" 
                Content="ВОЙТИ"
                Height="40"
                FontSize="16"
                FontWeight="Bold"
                Background="#FF9721"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnLogin_Click"
                Margin="0,0,0,10">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>

        <Button Grid.Row="7" 
                Content="Я сотрудник"
                Height="35"
                FontSize="14"
                Background="Transparent"
                BorderBrush="#FF9721"
                BorderThickness="2"
                Foreground="#FF9721"
                Cursor="Hand"
                Click="BtnEmployee_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Page>