<Page x:Class="Restoran.Pages.EmployeeMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель сотрудника"
      Height="500" 
      Width="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Панель сотрудника" 
                       FontSize="20" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="TxtEmployeeName"
                       Text="" 
                       FontSize="12"
                       Margin="0,5,0,0"/>
            <TextBlock x:Name="TxtEmployeePosition"
                       Text="" 
                       FontSize="12"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Меню:" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Button Content="Заказы"
                    Height="30"
                    Margin="0,5"
                    Click="BtnOrders_Click"/>

            <Button Content="Меню и блюда"
                    Height="30"
                    Margin="0,5"
                    Click="BtnMenu_Click"/>

            <Button Content="Мои смены"
                    Height="30"
                    Margin="0,5"
                    Click="BtnShifts_Click"/>

            <Button Content="Клиенты"
                    Height="30"
                    Margin="0,5"
                    Click="BtnClients_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Информация:" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="TxtOrdersCount"
                       Text="Заказов сегодня: 0"/>

            <TextBlock x:Name="TxtDishesCount"
                       Text="Активных блюд: 0"
                       Margin="0,5,0,0"/>

            <Separator Margin="0,15"/>

            <Button Content="Выйти"
                    Height="30"
                    Width="100"
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0"
                    Click="BtnLogout_Click"/>
        </StackPanel>
    </Grid>
</Page>