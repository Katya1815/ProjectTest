<Page x:Class="Restoran.Pages.EmployeeMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель администратора">

    <Grid Background="#FFF3E0">

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="250">

            <Button Content="Заказы"
                    Height="45"
                    Margin="10"
                    Click="BtnOrders_Click"/>

            <Button Content="Меню ресторана"
                    Height="45"
                    Margin="10"
                    Click="BtnMenu_Click"/>
            <Button Content="Сотрудники" 
                    Height="45"
                    Margin="10"
                    Click="EmployeesButton_Click"/>
            <Button Content="Клиенты"
                    Height="45"
                    Margin="10"
                    Click="BtnUsers_Click"/>

            <Button Content="Выход"
                    Height="45"
                    Margin="10"
                    Click="BtnLogout_Click"/>

        </StackPanel>

    </Grid>
</Page>