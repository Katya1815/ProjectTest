<Page x:Class="Restoran.Pages.DishesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restoran.Pages"
      mc:Ignorable="d" 
       d:DesignHeight="500" d:DesignWidth="900"
      Title="Блюда">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <StackPanel Grid.Row="0" Margin="10" Orientation="Horizontal">
            <Button Content="Добавить блюдо" Click="AddDish_Click" Margin="5" Padding="10,5"/>
            <TextBox x:Name="SearchDishBox" Width="200" Margin="5" 
                     PlaceholderText="Поиск блюда..."/>
            <ComboBox x:Name="CategoryFilter" Width="150" Margin="5"
                      SelectionChanged="FilterDishes">
                <ComboBoxItem Content="Все категории"/>
                <ComboBoxItem Content="Супы"/>
                <ComboBoxItem Content="Основные блюда"/>
                <ComboBoxItem Content="Десерты"/>
                <ComboBoxItem Content="Напитки"/>
            </ComboBox>
        </StackPanel>

        <!-- Список блюд -->
        <DataGrid x:Name="DishesGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="False"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id_блюда}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Наименование}" Width="200"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Категория_блюда}" Width="120"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Цена, StringFormat={}{0:C}}" Width="100"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Описание_блюда}" Width="300"/>
                <DataGridTemplateColumn Header="Действия" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Изм." Margin="2" Padding="5"
                                        Click="EditDish_Click" Tag="{Binding Id_блюда}"/>
                                <Button Content="Уд." Margin="2" Padding="5"
                                        Click="DeleteDish_Click" Tag="{Binding Id_блюда}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя панель -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Назад" Click="Back_Click" Margin="5" Padding="10,5"/>
            <Button Content="Сохранить изменения" Click="SaveChanges_Click" Margin="5" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Page>