<Page x:Class="Restoran.Pages.OrderCreatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restoran.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="900"
      Title="Создание заказа">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация о заказе -->
        <GroupBox Grid.Row="0" Header="Информация о заказе" Margin="0,0,0,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Столик:" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="TableComboBox" Grid.Column="1" Margin="5" Width="100"/>

                    <TextBlock Text="Клиент:" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="ClientComboBox" Grid.Column="3" Margin="5"/>
                </Grid>

                <TextBlock Text="Примечание:" Margin="5,10,5,0"/>
                <TextBox x:Name="NoteTextBox" Margin="5" Height="60" TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- Выбор блюд -->
        <GroupBox Grid.Row="1" Header="Выбор блюд" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Доступные блюда -->
                <DataGrid x:Name="AvailableDishesGrid" Grid.Column="0" Margin="5" 
                          AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Блюдо" Binding="{Binding Наименование}" Width="*"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Цена, StringFormat={}{0:C}}" Width="80"/>
                        <DataGridTemplateColumn Header="Добавить" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="+" Click="AddDishToOrder_Click" 
                                            Tag="{Binding Id_блюда}" Padding="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Кнопки управления -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10">
                    <Button Content="→" Margin="5" Padding="10" Click="AddDishToOrder_Click"/>
                    <Button Content="←" Margin="5" Padding="10" Click="RemoveDishFromOrder_Click"/>
                </StackPanel>

                <!-- Выбранные блюда -->
                <DataGrid x:Name="SelectedDishesGrid" Grid.Column="2" Margin="5"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Блюдо" Binding="{Binding Наименование}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Количество}" Width="60"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding Сумма, StringFormat={}{0:C}}" Width="80"/>
                        <DataGridTemplateColumn Header="Удалить" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="×" Click="RemoveDish_Click" 
                                            Tag="{Binding Id_блюда}" Padding="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- Итоговая информация -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Итоговая сумма:" FontWeight="Bold"/>
                    <TextBlock x:Name="TotalAmountText" FontSize="16" FontWeight="Bold" 
                               Foreground="Green" Text="0 ₽"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Отмена" Click="Cancel_Click" Margin="5" Padding="15,5"/>
                    <Button Content="Сохранить заказ" Click="SaveOrder_Click" Margin="5" 
                            Padding="15,5" Background="Green" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
