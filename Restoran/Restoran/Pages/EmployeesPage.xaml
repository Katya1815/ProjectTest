<Page x:Class="Restoran.Pages.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restoran.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="900"
     Title="Сотрудники"
      Loaded="Page_Loaded">

    <Grid Background="#FFF5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="#FF3F51B5" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Сотрудники ресторана" 
                           Foreground="White" 
                           FontSize="20" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Добавить сотрудника" 
                            Click="AddEmployee_Click"
                            Background="#FF4CAF50"
                            Foreground="White"
                            Padding="10,5"
                            Margin="5,0"/>
                    <Button Content="Экспорт в Excel" 
                            Click="ExportToExcel_Click"
                            Background="#FF2196F3"
                            Foreground="White"
                            Padding="10,5"
                            Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель поиска и фильтров -->
        <StackPanel Grid.Row="0" Margin="10,60,10,10" Orientation="Horizontal">
            <TextBox x:Name="SearchTextBox" 
                     Width="250" 
                     Height="35"
                     Margin="5"
                     Padding="10,0"
                     FontSize="14"
                     TextChanged="SearchTextBox_TextChanged"
                     PlaceholderText="Поиск по ФИО или должности...">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <ComboBox x:Name="PositionFilterComboBox"
                      Width="180"
                      Height="35"
                      Margin="5"
                      FontSize="14"
                      SelectionChanged="FilterChanged"
                      DisplayMemberPath="Наименование_должности">
                <ComboBox.Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </ComboBox.Style>
            </ComboBox>

            <ComboBox x:Name="SortComboBox"
                      Width="150"
                      Height="35"
                      Margin="5"
                      FontSize="14"
                      SelectionChanged="SortChanged">
                <ComboBoxItem Content="По ФИО (А-Я)"/>
                <ComboBoxItem Content="По ФИО (Я-А)"/>
                <ComboBoxItem Content="По должности"/>
                <ComboBoxItem Content="По дате рождения"/>
            </ComboBox>

            <Button Content="Сбросить фильтры" 
                    Click="ResetFilters_Click"
                    Background="#FF9E9E9E"
                    Foreground="White"
                    Padding="10,5"
                    Margin="5"/>
        </StackPanel>

        <!-- Таблица сотрудников -->
        <DataGrid x:Name="EmployeesDataGrid"
                  Grid.Row="1"
                  Margin="10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="None"
                  RowBackground="#FFFFFFFF"
                  AlternatingRowBackground="#FFF5F5F5"
                  BorderBrush="#FFDDDDDD"
                  BorderThickness="1"
                  FontSize="14">

            <DataGrid.Columns>
                <!-- Фото (заглушка) -->
                <DataGridTemplateColumn Header="Фото" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="40" Height="40" CornerRadius="20" 
                                    Background="#FFE0E0E0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Имя, StringFormat={}{0:g}}" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center"
                                           FontWeight="Bold"
                                           Foreground="#FF666666"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- ФИО -->
                <DataGridTextColumn Header="ФИО" Width="250">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0} {1} {2}">
                            <Binding Path="Фамилия"/>
                            <Binding Path="Имя"/>
                            <Binding Path="Отчество"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>

                <!-- Должность -->
                <DataGridTextColumn Header="Должность" 
                                    Binding="{Binding Должность.Наименование_должности}" 
                                    Width="150"/>

                <!-- Телефон -->
                <DataGridTextColumn Header="Телефон" 
                                    Binding="{Binding Номер_телефона}" 
                                    Width="130"/>

                <!-- Дата рождения -->
                <DataGridTextColumn Header="Дата рождения" 
                                    Binding="{Binding Дата_рождения, StringFormat=\{0:dd.MM.yyyy\}}" 
                                    Width="110"/>

                <!-- Возраст -->
                <DataGridTextColumn Header="Возраст" Width="70">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Дата_рождения">
                            <Binding.Converter>
                                <local:DateToAgeConverter/>
                            </Binding.Converter>
                        </Binding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>

                <!-- Роль -->
                <DataGridTextColumn Header="Роль" 
                                    Binding="{Binding Роль.Наименование_роли}" 
                                    Width="120"/>

                <!-- Действия -->
                <DataGridTemplateColumn Header="Действия" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="📋" 
                                        ToolTip="Просмотреть смены"
                                        Click="ViewShifts_Click"
                                        Tag="{Binding Id_сотрудника}"
                                        Style="{StaticResource IconButtonStyle}"
                                        Margin="2"/>

                                <Button Content="✏️" 
                                        ToolTip="Редактировать"
                                        Click="EditEmployee_Click"
                                        Tag="{Binding Id_сотрудника}"
                                        Style="{StaticResource IconButtonStyle}"
                                        Margin="2"/>

                                <Button Content="📞" 
                                        ToolTip="Позвонить"
                                        Click="CallEmployee_Click"
                                        Tag="{Binding Номер_телефона}"
                                        Style="{StaticResource IconButtonStyle}"
                                        Margin="2"/>

                                <Button Content="🗑️" 
                                        ToolTip="Удалить"
                                        Click="DeleteEmployee_Click"
                                        Tag="{Binding Id_сотрудника}"
                                        Style="{StaticResource IconButtonStyle}"
                                        Margin="2"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF3F51B5"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!-- Статистика -->
        <Border Grid.Row="2" Background="#FFF0F0F0" BorderBrush="#FFDDDDDD" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="{Binding ElementName=EmployeesDataGrid, Path=Items.Count, StringFormat=Всего сотрудников: {0}}"
                           FontWeight="Bold"
                           Margin="0,0,20,0"/>

                <TextBlock x:Name="StatisticsText"
                           Foreground="#FF666666"/>
            </StackPanel>
        </Border>

        <!-- Панель кнопок навигации -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="⟳ Обновить" 
                    Click="Refresh_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="5"/>

            <Button Content="← Назад" 
                    Click="Back_Click"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="5"/>
        </StackPanel>
    </Grid>
</Page>