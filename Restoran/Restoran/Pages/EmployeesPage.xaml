<Page x:Class="Restoran.Pages.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сотрудники"
      Background="#FFF5F0">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="УПРАВЛЕНИЕ СОТРУДНИКАМИ" 
                   FontSize="28" 
                   FontWeight="Bold"
                   Foreground="#FF9721"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Таблица сотрудников -->
        <DataGrid Grid.Row="1"
                  x:Name="EmployeesDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#FF9721"
                  BorderThickness="1"
                  Margin="0,0,0,20"
                  SelectionMode="Single">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF9721"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Height" Value="35"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FFF0E0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" 
                                    Binding="{Binding IdСотрудника}" 
                                    Width="50"/>

                <DataGridTextColumn Header="Фамилия" 
                                    Binding="{Binding Фамилия}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Имя" 
                                    Binding="{Binding Имя}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Отчество" 
                                    Binding="{Binding Отчество}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Логин" 
                                    Binding="{Binding Логин}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Должность" 
                                    Binding="{Binding IdДолжностиNavigation.НаименованиеДолжности}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Роль" 
                                    Binding="{Binding IdРолиNavigation.НаименованиеРоли}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Телефон" 
                                    Binding="{Binding НомерТелефона}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Дата рождения" 
                                    Binding="{Binding ДатаРождения, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">

            <Button Content="Добавить сотрудника"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="AddEmployee_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Редактировать"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="EditEmployee_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Удалить"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="DeleteEmployee_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Обновить"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="Refresh_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Page>