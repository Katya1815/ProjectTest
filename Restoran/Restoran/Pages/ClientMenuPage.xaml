<Page x:Class="Restoran.Pages.ClientMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личный кабинет клиента"
      Height="500" 
      Width="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Личный кабинет клиента" 
                       FontSize="20" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="TxtClientName"
                       Text="" 
                       FontSize="12"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Меню:" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Button Content="Мои заказы"
                    Height="30"
                    Margin="0,5"
                    Click="BtnOrders_Click"/>

            <Button Content="Меню ресторана"
                    Height="30"
                    Margin="0,5"
                    Click="BtnRestaurantMenu_Click"/>

            <Button Content="Сделать заказ"
                    Height="30"
                    Margin="0,5"
                    Click="BtnNewOrder_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Информация:" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="TxtRegistrationDate"
                       Text="Дата регистрации: "/>

            <TextBlock x:Name="TxtOrdersCount"
                       Text="Всего заказов: 0"
                       Margin="0,5,0,0"/>

            <Separator Margin="0,15"/>

            <Button Content="Выйти"
                    Height="30"
                    Width="100"
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0"
                    Click="BtnLogout_Click"/>
        </StackPanel>
    </Grid>
</Page>