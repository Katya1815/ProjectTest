<Page x:Class="Restoran.Pages.ClientMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель клиента">

    <Grid Background="#FFF3E0">

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="250">

            <Button Content="Меню"
                    Height="45"
                    Margin="10"
                    Click="BtnMenu_Click"/>

            <Button Content="Мои заказы"
                    Height="45"
                    Margin="10"
                    Click="BtnOrders_Click"/>

            <Button Content="Корзина"
                    Height="45"
                    Margin="10"
                    Click="BtnCart_Click"/>

            <Button Content="Выход"
                    Height="45"
                    Margin="10"
                    Click="BtnLogout_Click"/>

        </StackPanel>

    </Grid>
</Page>