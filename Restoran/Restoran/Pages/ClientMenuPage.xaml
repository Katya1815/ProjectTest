<Page x:Class="Restoran.Pages.ClientMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель клиента"
      Background="#FFF5F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="ПАНЕЛЬ КЛИЕНТА"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#FF9721"
                   HorizontalAlignment="Center"
                   Margin="0,30,0,20"/>

        <!-- Кнопки меню -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="300">

            <Button Content="🍽️ Меню"
                    Height="50"
                    Margin="0,10"
                    Click="BtnMenu_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="16"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="📋 Мои заказы"
                    Height="50"
                    Margin="0,10"
                    Click="BtnMyOrders_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="16"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="🚪 Выход"
                    Height="50"
                    Margin="0,10"
                    Click="BtnLogout_Click"
                    Background="Transparent"
                    BorderBrush="#FF9721"
                    BorderThickness="2"
                    Foreground="#FF9721"
                    FontSize="16"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </Grid>
</Page>