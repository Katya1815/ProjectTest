<Page x:Class="Restoran.Pages.ShiftsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Смены сотрудников"
      Background="#FFF5F0">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="УПРАВЛЕНИЕ СМЕНАМИ"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#FF9721"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Таблица смен -->
        <DataGrid Grid.Row="1"
                  x:Name="ShiftsDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#FF9721"
                  BorderThickness="1"
                  Margin="0,0,0,20"
                  SelectionMode="Single"
                  RowHeight="40"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#FFE0B2"
                  VerticalGridLinesBrush="Transparent"
                  HeadersVisibility="Column">

            <DataGrid.Resources>
                <!-- Стиль заголовков -->
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF9721"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Height" Value="45"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#FFB85E"/>
                    <Setter Property="Padding" Value="8,5"/>
                </Style>

                <!-- Стиль строк -->
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Height" Value="45"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FFF0E0"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FFF5E8"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль ячеек -->
                <Style TargetType="DataGridCell">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- № колонка (ID) -->
                <DataGridTextColumn Header="№" 
                                    Binding="{Binding id_смены}" 
                                    Width="55">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#FF9721"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Сотрудник -->
                <DataGridTextColumn Header="Сотрудник" 
                                    Binding="{Binding EmployeeName}" 
                                    Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#333333"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Должность -->
                <DataGridTextColumn Header="Должность" 
                                    Binding="{Binding Position}" 
                                    Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="Foreground" Value="#666666"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Дата -->
                <DataGridTextColumn Header="Дата" 
                                    Binding="{Binding дата_смены, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Начало -->
                <DataGridTextColumn Header="Начало" 
                                    Binding="{Binding начало_смены, StringFormat={}{0:HH\\:mm}}" 
                                    Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Конец -->
                <DataGridTextColumn Header="Конец" 
                                    Binding="{Binding конец_смены, StringFormat={}{0:HH\\:mm}}" 
                                    Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Продолжительность -->
                <DataGridTextColumn Header="Продолжительность" 
                                    Binding="{Binding Duration}" 
                                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#FF9721"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">

            <Button Content="➕ Добавить смену"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="BtnAddShift_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="13">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="✏️ Редактировать"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="BtnEditShift_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="13">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="🗑️ Удалить"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="BtnDeleteShift_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="13">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="🔄 Обновить"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="BtnRefresh_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="13">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Page>