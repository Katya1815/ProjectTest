<Page x:Class="Restoran.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация" 
      Height="450" 
      Width="300">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1" Grid.Column="1" 
                   Text="АВТОРИЗАЦИЯ" 
                   FontSize="24" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="2" Grid.Column="1" 
                   Text="Логин:" 
                   FontSize="14"
                   Margin="0,0,0,5"/>

        <TextBox Grid.Row="3" Grid.Column="1" 
                 x:Name="TBoxLogin"
                 Width="200"
                 Height="30"
                 FontSize="14"
                 Margin="0,0,0,15"/>

        <TextBlock Grid.Row="4" Grid.Column="1" 
                   Text="Пароль:" 
                   FontSize="14"
                   Margin="0,0,0,5"/>

        <PasswordBox Grid.Row="5" Grid.Column="1" 
                     x:Name="TBoxPassword"
                     Width="200"
                     Height="30"
                     FontSize="14"
                     Margin="0,0,0,15"/>

        <Button Grid.Row="6" Grid.Column="1" 
                Content="ВОЙТИ"
                Width="200"
                Height="40"
                FontSize="16"
                Background="#4CAF50"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnLogin_Click"
                Margin="0,0,0,10"/>

        <Button Grid.Row="7" Grid.Column="1" 
                Content="Я клиент"
                Width="200"
                Height="35"
                FontSize="14"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnClient_Click"/>
    </Grid>
</Page>