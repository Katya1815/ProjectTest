<Page x:Class="Restoran.Pages.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Клиенты"
      Background="#FFF5F0">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="УПРАВЛЕНИЕ КЛИЕНТАМИ" 
                   FontSize="28" 
                   FontWeight="Bold"
                   Foreground="#FF9721"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="UsersDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#FF9721"
                  BorderThickness="1"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SelectionMode="Single"
                  Padding="0"
                  RowHeaderWidth="0">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF9721"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Height" Value="35"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Остальные колонки растягиваются -->
                <DataGridTextColumn Header="ID" Binding="{Binding IdКлиента}" Width="60"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding Фамилия}" Width="120"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding Имя}" Width="120"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding Отчество}" Width="120"/>
                <DataGridTextColumn Header="Дата регистрации" Binding="{Binding ДатаРегистрацииВСистеме, StringFormat={}{0:dd.MM.yyyy}}" Width="130"/>
                <DataGridTextColumn Header="Примечания" Binding="{Binding Примечания}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">

            <Button Content="Добавить клиента"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="AddClient_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"/>

            <Button Content="Редактировать"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="EditClient_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"/>

            <Button Content="Удалить"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="DeleteClient_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"/>

            <Button Content="Обновить"
                    Width="150"
                    Height="40"
                    Margin="5"
                    Click="Refresh_Click"
                    Background="#FF9721"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Page>