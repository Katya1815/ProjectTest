<Page x:Class="Restoran.Pages.MakeOrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Новый заказ"
      Background="#FFF5F0">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="НОВЫЙ ЗАКАЗ" 
                   FontSize="28" 
                   FontWeight="Bold"
                   Foreground="#FF9721"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

        <!-- Выбор столика -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Выберите столик:" 
                       FontWeight="Bold"
                       Foreground="#FF9721"
                       FontSize="16"
                       Margin="0,0,0,10"/>
            <ComboBox x:Name="TableComboBox"
                      Height="40"
                      Width="200"
                      HorizontalAlignment="Left"
                      Background="White"
                      BorderBrush="#FF9721"
                      BorderThickness="2">
                <ComboBoxItem Content="Столик 1" Tag="1" IsSelected="True"/>
                <ComboBoxItem Content="Столик 2" Tag="2"/>
                <ComboBoxItem Content="Столик 3" Tag="3"/>
                <ComboBoxItem Content="Столик 4" Tag="4"/>
                <ComboBoxItem Content="Столик 5" Tag="5"/>
            </ComboBox>
        </StackPanel>

        <!-- Список блюд -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Меню:" 
                       FontWeight="Bold"
                       Foreground="#FF9721"
                       FontSize="16"
                       Margin="0,0,0,10"/>

            <TextBox x:Name="SearchBox"
                     Height="35"
                     Margin="0,0,0,10"
                     Padding="10,0"
                     BorderBrush="#FF9721"
                     BorderThickness="1"
                     TextChanged="SearchBox_TextChanged"
                     ToolTip="Введите название блюда для поиска"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="300">
                <ItemsControl x:Name="MenuItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#FF9721"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="10"
                                    Margin="0,0,0,10"
                                    Background="White">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Название и описание -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="{Binding Наименование}" 
                                                   FontSize="16" 
                                                   FontWeight="Bold"
                                                   Foreground="#FF9721"/>
                                        <TextBlock Text="{Binding ОписаниеБлюда}" 
                                                   FontSize="12"
                                                   Foreground="#666666"
                                                   TextWrapping="Wrap"
                                                   Margin="0,5,0,5"/>
                                    </StackPanel>

                                    <!-- Цена -->
                                    <TextBlock Grid.Row="0" 
                                               Grid.Column="1" 
                                               Text="{Binding Цена, StringFormat={}{0:N2} ₽}"
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#FF9721"
                                               VerticalAlignment="Center"
                                               Margin="20,0,10,0"/>

                                    <!-- Категория -->
                                    <StackPanel Grid.Row="1" 
                                                Grid.Column="0" 
                                                Orientation="Horizontal"
                                                Margin="0,5,0,0">
                                        <TextBlock Text="Категория:" 
                                                   Foreground="#FF9721"
                                                   Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding КатегорияБлюда}" 
                                                   Foreground="#666666"/>
                                    </StackPanel>

                                    <!-- Кнопка добавления -->
                                    <Button Grid.Row="1" 
                                            Grid.Column="1"
                                            Content="➕ Добавить"
                                            Width="80"
                                            Height="30"
                                            Click="BtnAddDish_Click"
                                            Tag="{Binding IdБлюда}"
                                            Background="Orange"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="10,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- Корзина -->
        <StackPanel Grid.Row="3" Margin="0,20,0,0">
            <Border BorderBrush="#FF9721"
                    BorderThickness="2"
                    CornerRadius="5"
                    Padding="10"
                    Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Корзина" 
                               FontWeight="Bold"
                               Foreground="#FF9721"
                               FontSize="16"
                               Margin="0,0,0,10"/>

                    <ListBox x:Name="CartListBox"
                             Grid.Row="1"
                             Height="100"
                             Margin="0,0,0,10"
                             Background="#FFF5F0"
                             BorderBrush="#FF9721"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DishName}" 
                                               Foreground="#FF9721"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N2} ₽}" 
                                               Foreground="#666666"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="Итого:" 
                                   FontWeight="Bold"
                                   Foreground="#FF9721"
                                   FontSize="18"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:Name="TotalPriceText"
                                   Grid.Column="1"
                                   FontWeight="Bold"
                                   Foreground="#FF9721"
                                   FontSize="18"
                                   Margin="10,0,20,0"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Очистить"
                                    Width="80"
                                    Height="35"
                                    Margin="5"
                                    Click="BtnClearCart_Click"
                                    Background="Transparent"
                                    BorderBrush="#FF9721"
                                    BorderThickness="2"
                                    Foreground="#FF9721"/>

                            <Button Content="Оформить заказ"
                                    Width="120"
                                    Height="35"
                                    Margin="5"
                                    Click="BtnPlaceOrder_Click"
                                    Background="#FF9721"
                                    Foreground="White"
                                    BorderThickness="0"/>

                            <Button Content="Отмена"
                                    Width="80"
                                    Height="35"
                                    Margin="5"
                                    Click="BtnCancel_Click"
                                    Background="Transparent"
                                    BorderBrush="#FF9721"
                                    BorderThickness="2"
                                    Foreground="#FF9721"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Page>