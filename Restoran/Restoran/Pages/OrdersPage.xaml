<Page x:Class="Restoran.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы"
      Background="#FFF3E0">

    <Page.Resources>
        <!-- стиль кнопок -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF8C00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- стиль заголовков таблицы -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FF8C00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- Таблица заказов -->
        <DataGrid x:Name="OrdersGrid"
                  Grid.Row="0"
                  Margin="20,10,20,10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowBackground="White"
                  AlternatingRowBackground="#FFE0B2"
                  GridLinesVisibility="None">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="60" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Клиент" Width="200" Binding="{Binding ClientName}"/>
                <DataGridTextColumn Header="Блюдо" Width="200" Binding="{Binding Dish}"/>
                <DataGridTextColumn Header="Количество" Width="120" Binding="{Binding Quantity}"/>
                <DataGridTextColumn Header="Статус" Width="150" Binding="{Binding Status}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Обновить" Width="150" Height="40" Margin="10" Click="BtnRefresh_Click"/>
            <Button Content="Завершить заказ" Width="180" Height="40" Margin="10" Click="BtnComplete_Click"/>
            <Button Content="Удалить заказ" Width="150" Height="40" Margin="10" Click="BtnDelete_Click"/>
        </StackPanel>
    </Grid>
</Page>