<Page x:Class="Restoran.Pages.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Меню ресторана"
      Background="#FFF5F0">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="МЕНЮ РЕСТОРАНА" 
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="#FF9721"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Фильтр по категориям -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Категории:" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"
                       Foreground="#FF9721"/>

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Все"
                            Height="35"
                            Width="80"
                            Margin="0,0,5,0"
                            Click="BtnAllCategories_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Пицца"
                            Height="35"
                            Width="80"
                            Margin="5,0"
                            Click="BtnPizzaCategory_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Паста"
                            Height="35"
                            Width="80"
                            Margin="5,0"
                            Click="BtnPastaCategory_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Салаты"
                            Height="35"
                            Width="80"
                            Margin="5,0"
                            Click="BtnSaladsCategory_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Супы"
                            Height="35"
                            Width="80"
                            Margin="5,0"
                            Click="BtnSoupsCategory_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Роллы"
                            Height="35"
                            Width="80"
                            Margin="5,0"
                            Click="BtnRollsCategory_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Бургеры"
                            Height="35"
                            Width="80"
                            Margin="5,0"
                            Click="BtnBurgersCategory_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Гарниры"
                            Height="35"
                            Width="80"
                            Margin="5,0"
                            Click="BtnSidesCategory_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Десерты"
                            Height="35"
                            Width="80"
                            Margin="5,0"
                            Click="BtnDessertsCategory_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Напитки"
                            Height="35"
                            Width="80"
                            Margin="5,0,0,0"
                            Click="BtnDrinksCategory_Click"
                            Background="#FF9721"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <!-- Список блюд на весь экран -->
        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="MenuItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#FF9721"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="15"
                                Margin="0,0,0,10"
                                Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="{Binding Наименование}" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#FF9721"/>
                                    <TextBlock Text="{Binding Описание}" 
                                               FontSize="12"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <TextBlock Grid.Row="0" 
                                           Grid.Column="1" 
                                           Text="{Binding Цена, StringFormat={}{0:N2} ₽}"
                                           FontSize="18" 
                                           FontWeight="Bold"
                                           Foreground="#FF9721"
                                           VerticalAlignment="Center"
                                           Margin="20,0,0,0"/>

                                <StackPanel Grid.Row="1" 
                                            Grid.Column="0" 
                                            Orientation="Horizontal"
                                            Margin="0,10,0,0">
                                    <TextBlock Text="Категория:" 
                                               Foreground="#FF9721"
                                               Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Категория}" 
                                               Foreground="#666666"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>